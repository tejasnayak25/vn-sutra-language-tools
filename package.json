{
  "name": "vnsutra-language-tools",
  "displayName": "VN-Sutra Language Tools",
  "description": "Language tools and project workflow for VN-Sutra .vn files: highlighting, autocomplete, linting, project creation, and npm script runners.",
  "version": "0.0.4",
  "publisher": "tejasnayak25",
  "author": "Tejas Nayak",
  "homepage": "https://github.com/tejasnayak25/vn-sutra-language-tools#readme",
  "bugs": {
    "url": "https://github.com/tejasnayak25/vn-sutra-language-tools/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tejasnayak25/vn-sutra-language-tools.git"
  },
  "license": "MIT",
  "qna": "https://github.com/tejasnayak25/vn-sutra-language-tools/discussions",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "icon": "media/icon.png",
  "keywords": [
    "vn",
    "visual novel",
    "language support",
    "syntax highlighting",
    "autocomplete",
    "lint",
    "scaffolding",
    "project bootstrap",
    "npm scripts"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vnsutra.createProject",
        "title": "Create New VN Project",
        "category": "VN-Sutra"
      },
      {
        "command": "vnsutra.runProjectSetup",
        "title": "Run Project Setup (npm install + npm run dev)",
        "category": "VN-Sutra"
      },
      {
        "command": "vnsutra.runWorkspaceScriptPicker",
        "title": "Run NPM Script From package.json",
        "category": "VN-Sutra"
      },
      {
        "command": "vnsutra.refreshScriptCommands",
        "title": "Refresh Dynamic Script Commands",
        "category": "VN-Sutra"
      }
    ],
    "languages": [
      {
        "id": "vn",
        "aliases": [
          "VN-Sutra",
          "vn"
        ],
        "extensions": [
          ".vn"
        ],
        "icon": {
          "light": "./media/vn-file-icon.svg",
          "dark": "./media/vn-file-icon.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vn",
        "scopeName": "source.vn",
        "path": "./syntaxes/vn.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "vn",
        "path": "./snippets/vn.code-snippets"
      }
    ],
    "configuration": {
      "title": "VN-Sutra",
      "properties": {
        "vnsutra.lint.unknownLine": {
          "type": "boolean",
          "default": true,
          "description": "Warn on lines that do not match known VN syntax and will fall back to raw dialog."
        },
        "vnsutra.lint.requireSceneHeader": {
          "type": "boolean",
          "default": true,
          "description": "Warn when non-comment lines appear before the first [scene: ...] header."
        },
        "vnsutra.lint.requireIndentStep": {
          "type": "boolean",
          "default": true,
          "description": "Warn when indentation is not in 4-space steps for nested VN blocks."
        },
        "vnsutra.lint.warnTabIndent": {
          "type": "boolean",
          "default": true,
          "description": "Warn when leading tabs are used for indentation."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "compile-tests": "tsc -p ./test/tsconfig.json",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "npm run compile && npm run compile-tests && node ./out-test/runTest.js",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.2",
    "mocha": "^10.7.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  }
}
